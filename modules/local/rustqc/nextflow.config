process {
    withName: 'RUSTQC' {
        publishDir = [
            // dupRadar plots (PNG + SVG)
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/dupradar" },
                mode: params.publish_dir_mode,
                pattern: "*_{duprateExpDens,duprateExpBoxplot,expressionHist}.{png,svg}"
            ],
            // dupRadar matrix/stats
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/dupradar" },
                mode: params.publish_dir_mode,
                pattern: "*_{dupMatrix,intercept_slope}.txt"
            ],
            // featureCounts
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/featurecounts" },
                mode: params.publish_dir_mode,
                pattern: "*.featureCounts.tsv{,.summary}"
            ],
            // Biotype counts
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/featurecounts" },
                mode: params.publish_dir_mode,
                pattern: "*.biotype_counts{,_mqc,_rrna_mqc}.tsv"
            ],
            // RSeQC: bam_stat
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/bam_stat" },
                mode: params.publish_dir_mode,
                pattern: "*.bam_stat.txt"
            ],
            // RSeQC: infer_experiment
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/infer_experiment" },
                mode: params.publish_dir_mode,
                pattern: "*.infer_experiment.txt"
            ],
            // RSeQC: read_duplication
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/read_duplication" },
                mode: params.publish_dir_mode,
                pattern: "*.{pos,seq}.DupRate.xls"
            ],
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/read_duplication" },
                mode: params.publish_dir_mode,
                pattern: "*.DupRate_plot.{png,svg}"
            ],
            // RSeQC: read_distribution
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/read_distribution" },
                mode: params.publish_dir_mode,
                pattern: "*.read_distribution.txt"
            ],
            // RSeQC: junction_annotation
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/junction_annotation" },
                mode: params.publish_dir_mode,
                pattern: "*.junction{.xls,.bed,_plot.r,_annotation.txt}"
            ],
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/junction_annotation" },
                mode: params.publish_dir_mode,
                pattern: "*.splice_{events,junction}.{png,svg}"
            ],
            // RSeQC: junction_saturation
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/junction_saturation" },
                mode: params.publish_dir_mode,
                pattern: "*.junctionSaturation_plot.{r,png,svg}"
            ],
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/junction_saturation" },
                mode: params.publish_dir_mode,
                pattern: "*.junctionSaturation_summary.txt"
            ],
            // RSeQC: inner_distance
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/inner_distance" },
                mode: params.publish_dir_mode,
                pattern: "*.inner_distance{.txt,_freq.txt,_summary.txt}"
            ],
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/inner_distance" },
                mode: params.publish_dir_mode,
                pattern: "*.inner_distance_plot.{r,png,svg}"
            ],
            // RSeQC: TIN
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/tin" },
                mode: params.publish_dir_mode,
                pattern: "*.tin{.xls,_summary.txt}"
            ],
            // preseq
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/preseq" },
                mode: params.publish_dir_mode,
                pattern: "*.lc_extrap.txt"
            ],
            // samtools
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/samtools" },
                mode: params.publish_dir_mode,
                pattern: "*.{flagstat,idxstats,stats}"
            ],
            // qualimap / gene body coverage
            [
                path: { "${params.outdir}/${params.aligner}/rustqc/qualimap" },
                mode: params.publish_dir_mode,
                pattern: "*{coverage_profile_along_genes_(total),rnaseq_qc_results}.txt"
            ]
        ]
    }
}
