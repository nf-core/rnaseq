/*
========================================================================================
    Nextflow config file for running nf-test tests
========================================================================================
*/

// TODO nf-core: Specify any additional parameters here
// Or any resources requirements
params {
    modules_testdata_base_path = 's3://ngi-igenomes/testdata/nf-core/modules/'
    pipelines_testdata_base_path = 's3://ngi-igenomes/testdata/nf-core/pipelines/rnaseq/3.15/'
    hisat2_build_memory = '3.GB'
    outdir = 'results'
}

aws.client.anonymous = true // fixes S3 access issues on self-hosted runners

// Impose sensible resource limits for testing
process {

    cpus   = 2
    memory = 3.GB
    time   = 2.h

    // Disable fq_lint validation for tests (allows null args)
    withName: 'FASTQ_QC_TRIM_FILTER_SETSTRANDEDNESS:FQ_LINT_AFTER_SORTMERNA' {
        ext.args = null
    }
    withName: 'FASTQ_QC_TRIM_FILTER_SETSTRANDEDNESS:FQ_LINT_AFTER_RIBO_REMOVAL' {
        ext.args = null
    }

    // Parabricks rnafq2bam requires more resources
    // Test flags:
    // --low-memory necessary on small GPU instances (less than 16 GB VRAM)
    // --read-files-command zcat allows for compressed input files
    // --x3 enables verbose output
    withName: '.*:PARABRICKS_RNA_FQ2BAM' {
        cpus        = 8
        memory      = 32.GB
        ext.args    = '--low-memory --read-files-command zcat --x3'
    }

}
