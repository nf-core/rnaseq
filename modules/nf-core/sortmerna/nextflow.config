process {
    withName: 'SORTMERNA' {
        ext.args   = '--num_alignments 1 -v --index 0'
        publishDir = [
            [
                path: { "${params.outdir}/${task.ext.publish_prefix}sortmerna" },
                mode: params.publish_dir_mode,
                pattern: "*.log"
            ],
            [
                path: { params.save_non_ribo_reads ? "${params.outdir}/${task.ext.publish_prefix}sortmerna" : params.outdir },
                mode: params.publish_dir_mode,
                pattern: "*.fastq.gz",
                saveAs: { filename -> params.save_non_ribo_reads ? filename : null }
            ]
        ]
    }
}
