process {
    withName: 'RUSTQC' {
        ext.args = {
            def biotype_attr = params.gencode ? "gene_type" : (params.featurecounts_group_type ?: '')
            biotype_attr ? "--biotype-attribute ${biotype_attr}" : ''
        }
        publishDir = [
            path: { "${params.outdir}/${params.aligner}/rustqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml')) return null
                // Strip the leading 'rustqc/' from the path to publish contents directly
                filename.startsWith('rustqc/') ? filename.substring(7) : filename
            }
        ]
    }
}
