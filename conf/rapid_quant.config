/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for rapid quantification mode
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-sample pseudo-alignment quantification with per-sample MultiQC reports.
    Skips alignment and alignment-dependent QC, but produces per-sample MultiQC
    reports covering FastQC, trimming, and Salmon metrics. Useful for very large
    cohorts where aggregation steps would exceed available memory.
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Rapid quantification'
    config_profile_description = 'Per-sample pseudo-alignment quantification with per-sample QC reports'

    skip_alignment             = true
    pseudo_aligner             = 'salmon'
    skip_quantification_merge  = true
    skip_multiqc               = false
    skip_bigwig                = true
    skip_stringtie             = true
    skip_markduplicates        = true
    skip_biotype_qc            = true
    skip_dupradar              = true
    skip_qualimap              = true
    skip_rseqc                 = true
    skip_preseq                = true
    skip_deseq2_qc             = true
}
