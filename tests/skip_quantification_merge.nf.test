nextflow_pipeline {

    name "Test pipeline with --skip_quantification_merge (per-sample tximport and MultiQC)"
    script "../main.nf"
    tag "pipeline"

    test("Params: --pseudo_aligner salmon --skip_alignment --skip_quantification_merge") {

        when {
            params {
                outdir = "$outputDir"
                pseudo_aligner = 'salmon'
                skip_alignment = true
                skip_quantification_merge = true
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // pipeline versions.yml file for multiqc from which Nextflow and pipeline versions are removed (all from the workflow key)
                    removeFromYamlMap("$outputDir/pipeline_info/nf_core_rnaseq_software_mqc_versions.yml", "Workflow"),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }

        cleanup {
            if (System.getenv("NFT_PROFILE")?.contains("docker")) {
                "docker system prune -f".execute()
            }
            new File("${launchDir}").deleteDir()
        }
    }

    test("Params: --pseudo_aligner salmon --skip_alignment --skip_quantification_merge - stub") {

        options "-stub"

        when {
            params {
                outdir = "$outputDir"
                pseudo_aligner = 'salmon'
                skip_alignment = true
                skip_quantification_merge = true
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // pipeline versions.yml file for multiqc from which Nextflow and pipeline versions are removed (all from the workflow key)
                    removeFromYamlMap("$outputDir/pipeline_info/nf_core_rnaseq_software_mqc_versions.yml", "Workflow"),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }

        cleanup {
            if (System.getenv("NFT_PROFILE")?.contains("docker")) {
                "docker system prune -f".execute()
            }
            new File("${launchDir}").deleteDir()
        }
    }
}
