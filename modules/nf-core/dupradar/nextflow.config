process {
    withName: 'DUPRADAR' {
        publishDir = [
            [
                path: { "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/dupradar/scatter_plot" },
                mode: params.publish_dir_mode,
                pattern: "*Dens.pdf"
            ],
            [
                path: { "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/dupradar/box_plot" },
                mode: params.publish_dir_mode,
                pattern: "*Boxplot.pdf"
            ],
            [
                path: { "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/dupradar/histogram" },
                mode: params.publish_dir_mode,
                pattern: "*Hist.pdf"
            ],
            [
                path: { "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/dupradar/gene_data" },
                mode: params.publish_dir_mode,
                pattern: "*Matrix.txt"
            ],
            [
                path: { "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/dupradar/intercepts_slope" },
                mode: params.publish_dir_mode,
                pattern: "*slope.txt"
            ]
        ]
    }
}
