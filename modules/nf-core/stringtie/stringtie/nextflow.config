process {
    withName: 'STRINGTIE_STRINGTIE' {
        ext.args   = { [
            '-v',
            '-e'
        ].join(' ').trim() }
    }
    // For calls from BAM_STRINGTIE_MERGE
    withName: 'NFCORE_RNASEQ:RNASEQ:BAM_STRINGTIE_MERGE:STRINGTIE_STRINGTIE' {
        ext.args = { "-v" }
    }
    publishDir = [
            path: { "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/stringtie" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]
}

