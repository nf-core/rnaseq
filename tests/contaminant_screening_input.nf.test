nextflow_pipeline {

    name "Test contaminant screening input selection"
    script "../main.nf"
    tag "pipeline"

    test("Params: contaminant screening unmapped input - stub") {

        options "-stub"

        when {
            params {
                outdir = "$outputDir"
                aligner = 'hisat2'
                skip_bigwig = true
                contaminant_screening = 'kraken2'
                kraken_db = "${params.modules_testdata_base_path}genomics/sarscov2/genome/db/kraken2.tar.gz"
            }
        }

        then {
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.trace.succeeded().size(),
                    removeFromYamlMap("$outputDir/pipeline_info/nf_core_rnaseq_software_mqc_versions.yml", "Workflow"),
                    stable_name,
                    stable_path
                ).match() }
            )
        }
    }

    test("Params: contaminant screening trimmed input with skip_alignment - stub") {

        options "-stub"

        when {
            params {
                outdir = "$outputDir"
                skip_alignment = true
                contaminant_screening = 'kraken2'
                contaminant_screening_input = 'trimmed'
                kraken_db = "${params.modules_testdata_base_path}genomics/sarscov2/genome/db/kraken2.tar.gz"
            }
        }

        then {
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.trace.succeeded().size(),
                    removeFromYamlMap("$outputDir/pipeline_info/nf_core_rnaseq_software_mqc_versions.yml", "Workflow"),
                    stable_name,
                    stable_path
                ).match() }
            )
        }
    }

    test("Params: contaminant_screening_input=trimmed screens pre-alignment reads") {

        // Verify Kraken2 screens trimmed/BBSplit-filtered reads (pre-alignment).
        // With contaminant_screening_input='trimmed', Kraken2 receives ALL trimmed
        // reads before any alignment step. The Kraken2 database is downloaded via
        // HTTPS from the public nf-core test-datasets bucket.

        when {
            params {
                def dbDir = new java.io.File(
                    new java.io.File(outputDir.toString()).parentFile, "kraken2_db"
                )
                if (!dbDir.exists()) {
                    dbDir.mkdirs()
                    def httpsUrl = "https://ngi-igenomes.s3.amazonaws.com/testdata/nf-core/modules/genomics/sarscov2/genome/db/kraken2.tar.gz"
                    def proc = ['bash', '-c',
                        "curl -fsSL '${httpsUrl}' | tar -xz --strip-components 1 -C '${dbDir}'"
                    ].execute()
                    proc.waitFor()
                }

                outdir                      = "$outputDir"
                contaminant_screening       = 'kraken2'
                contaminant_screening_input = 'trimmed'
                kraken_db                   = dbDir.absolutePath
                skip_bigwig                 = true
                skip_stringtie              = true
            }
        }

        then {
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            // Parse total reads processed per sample from Kraken2 reports.
            // Integer counts are deterministic even when file content (floating-point
            // percentages, multi-threaded output ordering) is not.
            // With trimmed input Kraken2 receives ALL reads, so counts are ~10-50x
            // higher than in the unmapped test, directly proving the correct code path.
            def krakenReportDir = file("$outputDir/star_salmon/contaminants/kraken2/kraken_reports")
            def krakenReadCounts = krakenReportDir.listFiles()
                .sort { it.name }
                .collectEntries { report ->
                    def total = 0L
                    report.readLines().each { line ->
                        def parts = line.trim().split('\t')
                        if (parts.size() >= 4 && parts[3] in ['U', 'R']) { total += parts[1].toLong() }
                    }
                    [report.name, total]
                }
            assertAll(
                { assert workflow.success },
                { assert workflow.trace.succeeded().findAll { it.name.contains('BBMAP_BBSPLIT') }.size() > 0 },
                { assert workflow.trace.succeeded().findAll { it.name.contains('KRAKEN2') }.size() > 0 },
                { assert krakenReadCounts == [
                    "RAP1_IAA_30M_REP1.kraken2.report.txt": 49593L,
                    "RAP1_UNINDUCED_REP1.kraken2.report.txt": 48567L,
                    "RAP1_UNINDUCED_REP2.kraken2.report.txt": 97654L,
                    "WT_REP1.kraken2.report.txt": 99225L,
                    "WT_REP2.kraken2.report.txt": 49550L
                ] },
                { assert snapshot(
                    workflow.trace.succeeded().size(),
                    removeFromYamlMap("$outputDir/pipeline_info/nf_core_rnaseq_software_mqc_versions.yml", "Workflow").findAll { it.key != "KRAKEN2" },
                    stable_name,
                    stable_path
                ).match() }
            )
        }
    }

    test("Params: contaminant_screening_input=unmapped (default) screens post-alignment reads") {

        // Contrast test: with the default 'unmapped' input, Kraken2 screens only
        // post-alignment unmapped reads. With the yeast test data most reads align
        // to the reference, so Kraken2 receives far fewer reads (~850–9k) than in
        // the trimmed test (~49k–100k), proving the two code paths use different inputs.

        when {
            params {
                def dbDir = new java.io.File(
                    new java.io.File(outputDir.toString()).parentFile, "kraken2_db"
                )
                if (!dbDir.exists()) {
                    dbDir.mkdirs()
                    def httpsUrl = "https://ngi-igenomes.s3.amazonaws.com/testdata/nf-core/modules/genomics/sarscov2/genome/db/kraken2.tar.gz"
                    def proc = ['bash', '-c',
                        "curl -fsSL '${httpsUrl}' | tar -xz --strip-components 1 -C '${dbDir}'"
                    ].execute()
                    proc.waitFor()
                }

                outdir                = "$outputDir"
                contaminant_screening = 'kraken2'
                // contaminant_screening_input left at default ('unmapped')
                kraken_db             = dbDir.absolutePath
                skip_bigwig           = true
                skip_stringtie        = true
            }
        }

        then {
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            // Parse total reads processed per sample from Kraken2 reports.
            // With unmapped input, Kraken2 only receives the small fraction of reads
            // that did not align to the reference (~850–9k vs ~49k–100k in the
            // trimmed test), directly proving the post-alignment code path is taken.
            def krakenReportDir = file("$outputDir/star_salmon/contaminants/kraken2/kraken_reports")
            def krakenReadCounts = krakenReportDir.listFiles()
                .sort { it.name }
                .collectEntries { report ->
                    def total = 0L
                    report.readLines().each { line ->
                        def parts = line.trim().split('\t')
                        if (parts.size() >= 4 && parts[3] in ['U', 'R']) { total += parts[1].toLong() }
                    }
                    [report.name, total]
                }
            assertAll(
                { assert workflow.success },
                { assert workflow.trace.succeeded().findAll { it.name.contains('STAR_ALIGN') }.size() > 0 },
                { assert workflow.trace.succeeded().findAll { it.name.contains('KRAKEN2') }.size() > 0 },
                { assert krakenReadCounts == [
                    "RAP1_IAA_30M_REP1.kraken2.report.txt": 3826L,
                    "RAP1_UNINDUCED_REP1.kraken2.report.txt": 854L,
                    "RAP1_UNINDUCED_REP2.kraken2.report.txt": 1811L,
                    "WT_REP1.kraken2.report.txt": 8928L,
                    "WT_REP2.kraken2.report.txt": 4197L
                ] },
                { assert snapshot(
                    workflow.trace.succeeded().size(),
                    removeFromYamlMap("$outputDir/pipeline_info/nf_core_rnaseq_software_mqc_versions.yml", "Workflow").findAll { it.key != "KRAKEN2" },
                    stable_name,
                    stable_path
                ).match() }
            )
        }
    }
}
