process {
    withName: 'RUSTQC' {
        ext.args = {
            def biotype_attr = params.gencode ? "gene_type" : (params.featurecounts_group_type ?: '')
            [
                biotype_attr ? "--biotype-attribute ${biotype_attr}" : '',
                '--preseq-seed 1 --preseq-seg-len 100000000',
                '--tin-seed 1 --junction-saturation-seed 1',
            ].join(' ').trim()
        }
        publishDir = [
            [path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/bam_stat" },           mode: params.publish_dir_mode, pattern: "*/rseqc/bam_stat/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/infer_experiment" },    mode: params.publish_dir_mode, pattern: "*/rseqc/infer_experiment/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/read_distribution" },   mode: params.publish_dir_mode, pattern: "*/rseqc/read_distribution/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/read_duplication" },    mode: params.publish_dir_mode, pattern: "*/rseqc/read_duplication/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/junction_annotation" }, mode: params.publish_dir_mode, pattern: "*/rseqc/junction_annotation/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/junction_saturation" }, mode: params.publish_dir_mode, pattern: "*/rseqc/junction_saturation/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/inner_distance" },      mode: params.publish_dir_mode, pattern: "*/rseqc/inner_distance/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/rseqc/tin" },                 mode: params.publish_dir_mode, pattern: "*/rseqc/tin/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/dupradar" },                  mode: params.publish_dir_mode, pattern: "*/dupradar/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/featurecounts" },             mode: params.publish_dir_mode, pattern: "*/featurecounts/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/preseq" },                    mode: params.publish_dir_mode, pattern: "*/preseq/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/samtools_stats" },            mode: params.publish_dir_mode, pattern: "*/samtools/*"],
            [path: { "${params.outdir}/${params.aligner}/rustqc/qualimap" },                  mode: params.publish_dir_mode, pattern: "*/qualimap/**"],
        ]
    }
}
