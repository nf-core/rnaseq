process {
    withName: 'BBMAP_BBSPLIT' {
        ext.args   = 'build=1 ambiguous2=all maxindel=150000 ow=f'
        publishDir = [
            [
                path: { "${params.outdir}/${task.ext.publish_prefix}bbsplit" },
                mode: params.publish_dir_mode,
                pattern: '*.txt'
            ],
            [
                path: { params.save_bbsplit_reads ? "${params.outdir}/${task.ext.publish_prefix}bbsplit" : params.outdir },
                mode: params.publish_dir_mode,
                pattern: '*.fastq.gz',
                saveAs: { filename -> params.save_bbsplit_reads ? filename : null }
            ]
        ]
    }
}
