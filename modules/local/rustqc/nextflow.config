process {
    withName: 'RUSTQC' {
        ext.args = {
            def biotype_attr = params.gencode ? "gene_type" : (params.featurecounts_group_type ?: '')
            biotype_attr ? "--biotype-attribute ${biotype_attr}" : ''
        }
        publishDir = [
            path: { "${params.outdir}/${params.aligner}/rustqc" },
            mode: params.publish_dir_mode,
        ]
    }
}
