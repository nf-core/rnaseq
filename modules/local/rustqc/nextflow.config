process {
    withName: 'RUSTQC' {
        ext.args = {
            def biotype_attr = params.gencode ? "gene_type" : (params.featurecounts_group_type ?: '')
            [
                biotype_attr ? "--biotype-attribute ${biotype_attr}" : '',
                '--preseq-seed 1 --preseq-seg-len 100000000',
                '--tin-seed 1 --junction-saturation-seed 1',
            ].join(' ').trim()
        }
        publishDir = [
            path: { "${params.outdir}/${params.aligner}/rustqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                // Strip sample prefix dir: SAMPLE/tool/file -> tool/file
                def stripped = filename.replaceFirst(/^[^\/]+\//, '')
                def base = stripped.tokenize('/').last()

                // Qualimap filenames (qualimapReport.html, rnaseq_qc_results.txt) are
                // not sample-prefixed, so re-insert the sample name as a subdirectory
                // to prevent collisions across samples.
                if (stripped.startsWith('qualimap/')) {
                    def sample = filename.split('/')[0]
                    return stripped.replaceFirst(/^qualimap\//, "qualimap/${sample}/")
                }

                // samtools/ -> samtools_stats/
                if (stripped.startsWith('samtools/')) {
                    return "samtools_stats/${base}"
                }

                // dupradar: route into file-type subdirs
                if (stripped.startsWith('dupradar/')) {
                    if (base.contains('Boxplot'))        return "dupradar/box_plot/${base}"
                    if (base.contains('ExpDens') && !base.contains('Curve_mqc'))
                                                         return "dupradar/scatter_plot/${base}"
                    if (base.contains('expressionHist')) return "dupradar/histogram/${base}"
                    if (base.contains('dupMatrix'))      return "dupradar/gene_data/${base}"
                    if (base.contains('intercept_slope')) return "dupradar/intercepts_slope/${base}"
                    return "dupradar/${base}"
                }

                // RSeQC tools with file-type subdirs
                if (stripped.startsWith('rseqc/')) {
                    def rseqcPath = stripped.replaceFirst(/^rseqc\//, '')
                    def tool = rseqcPath.tokenize('/')[0]

                    if (tool in ['junction_annotation', 'junction_saturation', 'inner_distance', 'read_duplication']) {
                        if (base.endsWith('.r'))         return "rseqc/${tool}/rscript/${base}"
                        if (base.endsWith('.png') || base.endsWith('.svg'))
                                                         return "rseqc/${tool}/plot/${base}"
                        if (base.endsWith('.xls'))        return "rseqc/${tool}/xls/${base}"
                        if (base.endsWith('.bed'))        return "rseqc/${tool}/bed/${base}"
                        if (base.endsWith('.junction_annotation.txt'))
                                                         return "rseqc/${tool}/log/${base}"
                        if (base.endsWith('.txt'))        return "rseqc/${tool}/txt/${base}"
                    }
                    return stripped
                }

                return stripped
            }
        ]
    }
}
