// Test config for extra_star_align_args deduplication
// Sets a flag that overlaps with a pipeline default to verify dedup works

params {
    aligner               = 'star_salmon'
    outdir                = 'results'
    publish_dir_mode      = 'copy'
    save_unaligned        = false
    save_align_intermeds  = false
    contaminant_screening = null
    prokaryotic           = false
    extra_star_align_args = '--outFilterMultimapNmax 10 --outFilterMismatchNoverLmax 0.1'
    seq_center            = null
    seq_platform          = null
}

includeConfig '../nextflow.config'

process {
    withName: 'STAR_GENOMEGENERATE.*' {
        ext.args = '--genomeSAindexNbases 9'
    }

    // Disable publishDir during tests
    withName: '.*ALIGN_STAR:STAR_ALIGN|.*ALIGN_STAR:STAR_ALIGN_IGENOMES|.*ALIGN_STAR:SENTIEON_STAR_ALIGN|.*ALIGN_STAR:PARABRICKS_RNA_FQ2BAM' {
        publishDir = []
    }
}
