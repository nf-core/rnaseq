process {
    withName: 'RUSTQC' {
        // Parabricks marks duplicates, but RustQC may not recognize its @PG provenance.
        // Skip only RustQC's duplicate-tool header check in this path.
        ext.args = { params.use_parabricks_star && !params.skip_markduplicates ? '--skip-dup-check' : '' }
        publishDir = [
            path: { "${params.outdir}/${params.aligner}/rustqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml')) return null
                // Strip the leading 'rustqc/' from the path to publish contents directly
                filename.startsWith('rustqc/') ? filename.substring(7) : filename
            }
        ]
    }
}
