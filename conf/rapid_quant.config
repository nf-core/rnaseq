/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for rapid quantification mode
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-sample pseudo-alignment quantification only, with no cross-sample
    merging and minimal QC. Useful for very large cohorts where aggregation
    steps would exceed available memory.
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Rapid quantification'
    config_profile_description = 'Per-sample pseudo-alignment quantification only'

    skip_alignment             = true
    pseudo_aligner             = 'salmon'
    skip_quantification_merge  = true
    skip_bigwig                = true
    skip_stringtie             = true
    skip_markduplicates        = true
    skip_biotype_qc            = true
    skip_dupradar              = true
    skip_qualimap              = true
    skip_rseqc                 = true
    skip_preseq                = true
    skip_deseq2_qc             = true
    skip_multiqc               = true
}
